<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>에너지 시장 통합 대시보드</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.0/papaparse.min.js"></script>
    <style>
        @import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
        body { font-family: 'Pretendard', sans-serif; margin: 0; background: #f1f3f5; color: #343a40; }
        .container { max-width: 1300px; margin: auto; padding: 40px 20px; }
        h1 { font-size: 28px; font-weight: 800; margin-bottom: 30px; display: flex; align-items: center; gap: 10px; }
        
        /* KPI 카드 레이아웃 */
        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .card { background: white; padding: 24px; border-radius: 16px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.04); transition: transform 0.2s; }
        .card:hover { transform: translateY(-5px); }
        .label { font-size: 13px; color: #868e96; font-weight: 600; margin-bottom: 8px; text-transform: uppercase; }
        .val-row { display: flex; align-items: baseline; gap: 10px; }
        .current-val { font-size: 32px; font-weight: 800; }
        .change { font-size: 15px; font-weight: 700; padding: 4px 8px; border-radius: 6px; }
        .up { color: #e03131; background: #fff5f5; }
        .down { color: #1971c2; background: #e7f5ff; }
        .sub-info { font-size: 12px; color: #adb5bd; margin-top: 12px; }

        /* 차트 컨트롤 섹션 */
        .chart-container { background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.04); }
        .controls { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 20px; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #f1f3f5; }
        .btn-group { display: flex; gap: 8px; flex-wrap: wrap; }
        .btn { border: 1px solid #dee2e6; background: white; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-size: 14px; font-weight: 600; transition: 0.2s; }
        .btn:hover { background: #f8f9fa; }
        .btn.active { background: #343a40; color: white; border-color: #343a40; }
        
        canvas { width: 100% !important; height: 450px !important; }
    </style>
</head>
<body>
    <div class="container">
        <h1>⚡ Energy Market Intelligence</h1>

        <div class="kpi-grid" id="kpiGrid"></div>

        <div class="chart-container">
            <div class="controls">
                <div>
                    <div class="label" style="margin-bottom: 10px;">기간 선택</div>
                    <div class="btn-group" id="rangeBtns">
                        <button class="btn active" onclick="setRange('1M')">1개월</button>
                        <button class="btn" onclick="setRange('3M')">3개월</button>
                        <button class="btn" onclick="setRange('1Y')">1년</button>
                        <button class="btn" onclick="setRange('MAX')">전체</button>
                    </div>
                </div>
                <div>
                    <div class="label" style="margin-bottom: 10px;">지표 전환</div>
                    <div class="btn-group" id="indicatorBtns"></div>
                </div>
            </div>
            <canvas id="mainChart"></canvas>
        </div>
    </div>

    <script>
        // [필독] '웹에 게시'에서 생성된 CSV URL을 여기에 넣으세요
        const CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vRljER-d5ZMRq-vxJ7yHPjtLJ9zL8s8mDJVB4aMANLCa1RPkQqmfUA-6loSdEKxw5QhT4DJUhpkuWMO/pub?gid=0&single=true&output=csv";

        let rawData = [];
        let chartObj = null;
        let config = {
            range: '1M',
            indicator: 'Brent' // 기본값
        };

        // 지표 메타데이터 정의 (시트 컬럼명과 1:1 매칭)
        const metrics = {
            "Brent": { label: "Brent 유가", unit: "$/bbl", color: "#e03131" },
            "WTI": { label: "WTI 유가", unit: "$/bbl", color: "#f08c00" },
            "HH": { label: "HH 천연가스", unit: "$/MMBtu", color: "#099268" },
            "JKM": { label: "JKM LNG", unit: "$/MMBtu", color: "#1971c2" },
            "SMP": { label: "SMP 육지", unit: "원/kWh", color: "#6741d9" },
            "TTF_Converted": { label: "TTF 환산", unit: "$/MMBtu", color: "#d63384" },
            "USD": { label: "원/달러 환율", unit: "원", color: "#495057" }
        };

        // 데이터 로드
        Papa.parse(CSV_URL, {
            download: true, header: true, skipEmptyLines: true,
            complete: (results) => {
                rawData = results.data.map(d => ({
                    date: new Date(d.Date),
                    Brent: parseFloat(d["Brent"]),
                    WTI: parseFloat(d["WTI"]),
                    HH: parseFloat(d["HH"]),
                    JKM: parseFloat(d["JKM"]),
                    SMP: parseFloat(d["SMP"]),
                    TTF_Converted: parseFloat(d["TTF($/MMBtu)"]), // 헤더 명칭 주의
                    USD: parseFloat(d["USD"])
                })).filter(d => !isNaN(d.date));
                
                initDashboard();
            }
        });

        function initDashboard() {
            renderKPI();
            initIndicatorBtns();
            updateChart();
        }

        // KPI 카드 렌더링 (오늘 vs 어제 비교)
        function renderKPI() {
            const grid = document.getElementById('kpiGrid');
            const latest = rawData[rawData.length - 1];
            const prev = rawData[rawData.length - 2];
            
            const displayKeys = ["Brent", "JKM", "SMP", "TTF_Converted"];
            
            grid.innerHTML = displayKeys.map(key => {
                const cur = latest[key] || 0;
                const old = prev[key] || 0;
                const diff = cur - old;
                const pct = ((diff / old) * 100).toFixed(2);
                const isUp = diff >= 0;

                return `
                    <div class="card">
                        <div class="label">${metrics[key].label}</div>
                        <div class="val-row">
                            <span class="current-val">${cur.toLocaleString(undefined, {minimumFractionDigits: 2})}</span>
                            <span class="change ${isUp ? 'up' : 'down'}">
                                ${isUp ? '▲' : '▼'} ${Math.abs(pct)}%
                            </span>
                        </div>
                        <div class="sub-info">전일 대비 ${diff.toFixed(2)} ${metrics[key].unit} 변동</div>
                    </div>
                `;
            }).join('');
        }

        function initIndicatorBtns() {
            const container = document.getElementById('indicatorBtns');
            container.innerHTML = Object.keys(metrics).map(key => `
                <button class="btn ${key === config.indicator ? 'active' : ''}" 
                        onclick="setIndicator('${key}')">${metrics[key].label}</button>
            `).join('');
        }

        function setRange(range) {
            config.range = range;
            document.querySelectorAll('#rangeBtns .btn').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');
            updateChart();
        }

        function setIndicator(key) {
            config.indicator = key;
            document.querySelectorAll('#indicatorBtns .btn').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');
            updateChart();
        }

        function updateChart() {
            const ctx = document.getElementById('mainChart').getContext('2d');
            const filtered = filterData();
            const meta = metrics[config.indicator];

            if (chartObj) chartObj.destroy();

            chartObj = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: filtered.map(d => d.date),
                    datasets: [{
                        label: meta.label,
                        data: filtered.map(d => d[config.indicator]),
                        borderColor: meta.color,
                        backgroundColor: meta.color + '22',
                        fill: true,
                        tension: 0.3,
                        borderWidth: 3,
                        pointRadius: 0,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { type: 'time', time: { unit: 'day' }, grid: { display: false } },
                        y: { beginAtZero: false, grid: { color: '#f1f3f5' } }
                    }
                }
            });
        }

        function filterData() {
            const end = rawData[rawData.length - 1].date;
            let start = new Date(end);
            if (config.range === '1M') start.setMonth(end.getMonth() - 1);
            else if (config.range === '3M') start.setMonth(end.getMonth() - 3);
            else if (config.range === '1Y') start.setFullYear(end.getFullYear() - 1);
            else return rawData;
            return rawData.filter(d => d.date >= start);
        }
    </script>
</body>
</html>
